# De'Longhi Coffee Link / Ayla IoT credentials
# See docs/reverse-engineering-guide.md for how to obtain these values

# App credentials (extracted from Coffee Link app via MITM proxy)
DELONGHI_AYLA_APP_ID=
DELONGHI_AYLA_APP_SECRET=

# --- Option A: Email/password (uses Gigya SSO, same flow as the Coffee Link app) ---
DELONGHI_EMAIL=
DELONGHI_PASSWORD=

# --- Option B: Raw SSO token (captured from app via MITM proxy) ---
# DELONGHI_AYLA_SSO_TOKEN=

# Region: EU endpoints are the default (De'Longhi is Italian).
# Override only if your account is on US/global servers.
# DELONGHI_AYLA_AUTH_BASE_URL=https://user-field.aylanetworks.com
# DELONGHI_AYLA_ADS_BASE_URL=https://ads-field.aylanetworks.com
